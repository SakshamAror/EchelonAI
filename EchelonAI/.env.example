# ── EchelonAI environment variables ───────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env to source control.

# ── Demo / live mode ──────────────────────────────────────────────────────────
# Default: true (shows hardcoded Nike/Nvidia/Tesla demo data, no API keys needed)
# Set to "false" to enable live analysis against real API endpoints
VITE_USE_DEMO=true

# Skip the agent progress animation and show results immediately (useful for dev)
# Default: false
VITE_BYPASS_DEMO_PROGRESS=false

# ── API keys (required for live mode) ─────────────────────────────────────────
# These can also be entered at runtime via the Settings panel (gear icon in nav).
# Keys entered in the UI are stored in browser localStorage and synced to the
# dev server in-memory — they do NOT need to be set here for normal use.
GROQ_API_KEY=gsk_...
TAVILY_API_KEY=tvly-...

# ── Model / runtime overrides ─────────────────────────────────────────────────
# Groq model used for alpha synthesis (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Path to Python binary for running agent scripts
# Defaults to .venv/bin/python if it exists, otherwise "python3"
AGENT_PYTHON_BIN=.venv/bin/python
